# =============================================================================
# mycoolwebsite - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.
# These variables are used for authentication, database access, and site configuration.

# -----------------------------------------------------------------------------
# Required: GitHub OAuth (for admin panel authentication)
# -----------------------------------------------------------------------------
# Create a GitHub OAuth App at: https://github.com/settings/applications/new
# Authorization callback URL: https://your-domain.com/api/auth/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# -----------------------------------------------------------------------------
# Required: Session Security
# -----------------------------------------------------------------------------
# Generate a secure random string (32+ characters)
# You can use: `openssl rand -base64 32` or a password manager
SESSION_SECRET=your_secure_random_session_secret_string

# -----------------------------------------------------------------------------
# Required: Site Configuration
# -----------------------------------------------------------------------------
# Your production domain (used for OAuth callbacks and CORS)
SITE_BASE_URL=https://coolmanyt.com

# -----------------------------------------------------------------------------
# Required: Supabase (for blog storage)
# -----------------------------------------------------------------------------
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_public_key

# -----------------------------------------------------------------------------
# Optional: GitHub Repository Settings
# -----------------------------------------------------------------------------
# Default: COOLmanYT/mycoolwebsite
GITHUB_OWNER=COOLmanYT
GITHUB_REPO=mycoolwebsite

# Branch to read/write allowlist from (default: main)
ALLOWLIST_BRANCH=main

# -----------------------------------------------------------------------------
# Optional: Admin Allowlist Management
# -----------------------------------------------------------------------------
# GitHub Personal Access Token with `repo` scope
# Required only if you want to edit the allowlist from the admin panel
# Create at: https://github.com/settings/tokens/new (select repo scope)
ALLOWLIST_GITHUB_TOKEN=ghp_your_personal_access_token

# Custom commit metadata for allowlist changes
ALLOWLIST_COMMIT_NAME=COOLman Admin Bot
ALLOWLIST_COMMIT_EMAIL=commitemail@example.com

# -----------------------------------------------------------------------------
# Optional: Discord Webhook (for blog post notifications)
# -----------------------------------------------------------------------------
# Create a webhook at: https://discord.com/app/developers
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_token

# -----------------------------------------------------------------------------
# Optional: YouTube API (for faster latest video fetching)
# -----------------------------------------------------------------------------
# Get an API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_data_api_key

# -----------------------------------------------------------------------------
# Optional: Analytics
# -----------------------------------------------------------------------------
# Vercel Speed Insights (already configured in package.json)
# No additional configuration needed

# MailerLite (for email subscriptions)
MAILERLITE_ACCOUNT_ID=your_mailerlite_account_id

# =============================================================================
